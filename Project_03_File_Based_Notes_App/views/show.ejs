<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title><%= filename %></title>
</head>

<body class="bg-zinc-950 text-white">

    <div class="max-w-4xl mx-auto px-6 py-12">

        <a href="/" class="inline-flex items-center gap-2 text-blue-400 hover:text-blue-300 mb-8">
            ← Back to Home
        </a>

        <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-8 shadow-2xl">

            <h1 class="text-4xl font-bold tracking-tight break-words">
                <%= filename %>
            </h1>

            <div class="w-full h-px bg-zinc-800 my-6"></div>

            <p class="text-zinc-300 leading-8 text-lg">
                <%= filedata %>
            </p>

        </div>

    </div>

</body>

</html>