<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title>Edit Post</title>
</head>

<body class="bg-zinc-950 text-white">

    <div class="min-h-screen flex items-center justify-center p-6">

        <div class="w-full max-w-3xl bg-zinc-900 border border-zinc-800 rounded-3xl p-8 shadow-2xl">

            <div class="mb-8">

                <h1 class="text-4xl font-bold">
                    ✏️ Edit Post
                </h1>

                <p class="text-zinc-400 mt-2">
                    Update your post and save the changes.
                </p>

            </div>

            <form action="/edit/<%= post._id %>" method="POST" class="space-y-6">

                <textarea
                    name="content"
                    rows="8"
                    class="w-full bg-zinc-800 border border-zinc-700 rounded-2xl p-5 text-white outline-none resize-none focus:border-blue-500 transition"><%= post.content %></textarea>

                <div class="flex gap-4">

                    <button
                        type="submit"
                        class="bg-blue-600 hover:bg-blue-700 px-6 py-3 rounded-xl font-semibold transition cursor-pointer">

                        💾 Save Changes

                    </button>

                    <a
                        href="/profile"
                        class="bg-zinc-700 hover:bg-zinc-600 px-6 py-3 rounded-xl font-semibold transition">

                        Cancel

                    </a>

                </div>

            </form>

        </div>

    </div>

</body>
</html>