<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport"
        content="width=device-width, initial-scale=1.0">

    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

    <title>Update Profile Picture</title>

</head>

<body class="bg-zinc-950 text-white">

    <!-- Navbar -->

    <nav class="border-b border-zinc-800 bg-zinc-900">

        <div class="max-w-6xl mx-auto flex justify-between items-center px-8 py-5">

            <h1 class="text-3xl font-bold">
                Update Profile Picture
            </h1>

            <a
                href="/profile"
                class="bg-zinc-800 hover:bg-zinc-700 transition px-5 py-2 rounded-xl font-semibold">

                ← Back

            </a>

        </div>

    </nav>

    <!-- Main -->

    <div class="min-h-[85vh] flex items-center justify-center px-5">

        <div class="w-full max-w-xl bg-zinc-900 border border-zinc-800 rounded-3xl p-8 shadow-2xl">

            <!-- Avatar -->

            <div class="flex justify-center mb-8">

                <img
                    id="preview"
                    src="/images/upload/<%= user.profilePic %>"
                    alt="Profile Picture"
                    class="w-40 h-40 rounded-full object-cover border-4 border-blue-500 shadow-xl"
                    name="profilePic">

            </div>

            <h1 class="text-4xl font-bold text-center">

                Upload New Picture

            </h1>

            <p class="text-zinc-400 text-center mt-3 mb-8">

                Choose a new profile picture.

            </p>

            <form
                action="/upload"
                method="POST"
                enctype="multipart/form-data"
                class="space-y-6">

                <label
                    for="profilePic"
                    class="flex flex-col items-center justify-center border-2 border-dashed border-zinc-700 hover:border-blue-500 transition rounded-3xl h-56 cursor-pointer bg-zinc-800">

                    <svg xmlns="http://www.w3.org/2000/svg"
                        class="w-14 h-14 text-blue-500"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor">

                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M7 16V4m0 0L3 8m4-4l4 4m6 8v4m0 0l4-4m-4 4l-4-4"/>

                    </svg>

                    <h2 class="text-xl font-semibold mt-4">

                        Click to Upload

                    </h2>

                    <p class="text-zinc-500 mt-2">

                        JPG • PNG • JPEG

                    </p>

                    <p
                        id="fileName"
                        class="text-blue-400 mt-4 font-medium">

                        No file selected

                    </p>

                </label>

                <input
                    id="profilePic"
                    type="file"
                    name="profilePic"
                    accept="image/*"
                    class="hidden">

                <button
                    type="submit"
                    class="w-full bg-blue-600 hover:bg-blue-700 transition py-3 rounded-xl font-semibold cursor-pointer">

                    Upload Profile Picture

                </button>

            </form>

        </div>

    </div>

    <script>

        const input = document.getElementById("profilePic");

        const preview = document.getElementById("preview");

        const fileName = document.getElementById("fileName");

        input.addEventListener("change", function () {

            const file = this.files[0];

            if (!file) return;

            fileName.textContent = file.name;

            const reader = new FileReader();

            reader.onload = function (e) {

                preview.src = e.target.result;

            }

            reader.readAsDataURL(file);

        });

    </script>

</body>

</html>