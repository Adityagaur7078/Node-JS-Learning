<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title>Register</title>
</head>

<body class="bg-zinc-950 text-white">

    <nav class="flex justify-between items-center px-8 py-6 border-b border-zinc-800">

        <h1 class="text-3xl font-bold">
            Auth System
        </h1>

        <a
            href="/login"
            class="bg-blue-600 hover:bg-blue-700 px-5 py-2 rounded-xl transition">

            Login

        </a>

    </nav>

    <div class="min-h-[90vh] flex items-center justify-center px-5">

        <div
            class="w-full max-w-md bg-zinc-900 border border-zinc-800 rounded-3xl p-8 shadow-2xl">

            <h1 class="text-4xl font-bold text-center">
                Create Account
            </h1>

            <p class="text-zinc-400 text-center mt-2 mb-8">

                Register to continue

            </p>

            <form
                action="/create"
                method="POST"
                class="space-y-5">

                <input
                    type="text"
                    name="username"
                    required
                    placeholder="Username"
                    class="w-full bg-zinc-800 border border-zinc-700 rounded-xl px-4 py-3 outline-none focus:border-blue-500">

                <input
                    type="email"
                    name="email"
                    required
                    placeholder="Email Address"
                    class="w-full bg-zinc-800 border border-zinc-700 rounded-xl px-4 py-3 outline-none focus:border-blue-500">

                <input
                    type="password"
                    name="password"
                    required
                    placeholder="Password"
                    class="w-full bg-zinc-800 border border-zinc-700 rounded-xl px-4 py-3 outline-none focus:border-blue-500">

                <input
                    type="number"
                    name="age"
                    required
                    placeholder="Age"
                    class="w-full bg-zinc-800 border border-zinc-700 rounded-xl px-4 py-3 outline-none focus:border-blue-500">

                <button
                    class="w-full bg-blue-600 hover:bg-blue-700 py-3 rounded-xl font-semibold cursor-pointer transition">

                    Register

                </button>

            </form>

            <p class="text-center text-zinc-400 mt-6">

                Already have an account?

                <a
                    href="/login"
                    class="text-blue-500 hover:text-blue-400">

                    Login

                </a>

            </p>

        </div>

    </div>

</body>

</html>