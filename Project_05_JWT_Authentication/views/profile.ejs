<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title>Profile</title>
</head>

<body class="bg-zinc-950 text-white">

    <!-- Navbar -->

    <nav class="flex justify-between items-center px-8 py-6 border-b border-zinc-800">

        <h1 class="text-3xl font-bold">
            Dashboard
        </h1>

        <a
            href="/logout"
            class="bg-red-600 hover:bg-red-700 px-5 py-2 rounded-xl transition">

            Logout

        </a>

    </nav>

    <!-- Main -->

    <div class="min-h-[90vh] flex items-center justify-center px-5">

        <div
            class="w-full max-w-lg bg-zinc-900 border border-zinc-800 rounded-3xl p-8 shadow-2xl">

            <!-- Avatar -->

            <div class="flex justify-center">

                <div
                    class="w-28 h-28 rounded-full bg-blue-600 flex items-center justify-center text-5xl font-bold">

                    <%= user.username.charAt(0).toUpperCase() %>

                </div>

            </div>

            <!-- Heading -->

            <h1 class="text-4xl font-bold text-center mt-6">

                Welcome

            </h1>

            <p class="text-center text-zinc-400 mt-2">

                You are successfully logged in.

            </p>

            <!-- User Details -->

            <div class="mt-8 space-y-5">

                <div
                    class="bg-zinc-800 rounded-xl p-4">

                    <p class="text-zinc-400 text-sm">

                        Username

                    </p>

                    <h2 class="text-xl font-semibold">

                        <%= user.username %>

                    </h2>

                </div>

                <div
                    class="bg-zinc-800 rounded-xl p-4">

                    <p class="text-zinc-400 text-sm">

                        Email

                    </p>

                    <h2 class="text-xl font-semibold break-all">

                        <%= user.email %>

                    </h2>

                </div>

                <div
                    class="bg-zinc-800 rounded-xl p-4">

                    <p class="text-zinc-400 text-sm">

                        Age

                    </p>

                    <h2 class="text-xl font-semibold">

                        <%= user.age %> Years

                    </h2>

                </div>

            </div>

        </div>

    </div>

</body>

</html>