<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title>All Users</title>
</head>

<body class="bg-zinc-950 text-white min-h-screen">

    <nav class="flex justify-between items-center p-6 border-b border-zinc-800">

        <h1 class="text-3xl font-bold">
            All Users
        </h1>

        <a
            href="/"
            class="bg-zinc-800 hover:bg-zinc-700 px-5 py-2 rounded-xl transition">

            Create User

        </a>

    </nav>

    <% if(users.length === 0){ %>

        <div class="flex items-center justify-center h-[70vh]">

            <div class="text-center">

                <h1 class="text-4xl font-bold">
                    No Users Found
                </h1>

                <p class="text-zinc-400 mt-2">
                    Create your first user.
                </p>

            </div>

        </div>

    <% } else { %>

        <div class="max-w-7xl mx-auto p-8 flex flex-wrap gap-8 justify-center">

            <% users.forEach(function(user){ %>

                <div
                    class="w-80 bg-zinc-900 border border-zinc-800 rounded-3xl overflow-hidden shadow-2xl hover:-translate-y-2 hover:border-blue-500 transition-all duration-300">

                    <div class="relative">

                        <img
                            class="w-full h-56 object-cover"
                            src="<%= user.image || 'https://images.unsplash.com/photo-1472099645785-5658abf4ff4e' %>"
                            alt="<%= user.name %>">

                        <div
                            class="absolute inset-0 bg-gradient-to-t from-zinc-900 to-transparent">
                        </div>

                    </div>

                    <div class="p-5">

                        <h2 class="text-2xl font-bold">
                            <%= user.name %>
                        </h2>

                        <p class="text-zinc-400 mt-2 break-all">
                            <%= user.email %>
                        </p>

                        <div class="flex gap-3 mt-6">

                            <a
                                href="/edit/<%= user._id %>"
                                class="flex-1 text-center bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded-xl font-medium transition">

                                Edit

                            </a>

                            <a
                                href="/delete/<%= user._id %>"
                                class="flex-1 text-center bg-red-600 hover:bg-red-700 px-4 py-2 rounded-xl font-medium transition">

                                Delete

                            </a>

                        </div>

                    </div>

                </div>

            <% }) %>

        </div>

    <% } %>

</body>

</html>